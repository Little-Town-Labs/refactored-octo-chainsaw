{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spyglass.local/schemas/product-harness/result-store.schema.json",
  "title": "Product Harness Result Store Snapshot",
  "type": "object",
  "required": [
    "schema_version",
    "run",
    "seed_records",
    "agent_invocations",
    "browser_artifacts",
    "webhook_captures",
    "observability_assertions",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "pth-result-store/v1" },
    "created_at": { "type": "string", "format": "date-time" },
    "run": {
      "type": "object",
      "required": ["run_id", "scenario", "environment", "started_at", "ended_at", "duration_ms", "status", "steps", "assertions", "artifacts", "summary"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "scenario": {
          "type": "object",
          "required": ["scenario_id", "version", "title", "mode"],
          "properties": {
            "scenario_id": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "title": { "type": "string", "minLength": 1 },
            "mode": { "enum": ["gate", "eval"] }
          },
          "additionalProperties": true
        },
        "environment": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "status": { "enum": ["passed", "failed", "invalid"] },
        "steps": { "type": "array" },
        "assertions": { "type": "array" },
        "artifacts": { "type": "array" },
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    },
    "seed_records": { "type": "array" },
    "agent_invocations": { "type": "array" },
    "browser_artifacts": { "type": "array" },
    "webhook_captures": { "type": "array" },
    "observability_assertions": { "type": "array" }
  },
  "additionalProperties": false
}
