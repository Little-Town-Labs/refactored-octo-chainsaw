{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spyglass.local/contracts/product-harness-result.schema.json",
  "title": "Spyglass Product Harness Run Result",
  "type": "object",
  "required": [
    "run_id",
    "scenario",
    "environment",
    "started_at",
    "ended_at",
    "duration_ms",
    "status",
    "steps",
    "assertions",
    "artifacts",
    "summary"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "scenario": {
      "type": "object",
      "required": ["scenario_id", "version", "title", "mode"],
      "properties": {
        "scenario_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "mode": { "enum": ["gate", "eval"] },
        "owner": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "app_url": { "type": "string" }
      },
      "additionalProperties": true
    },
    "git": {
      "type": "object",
      "properties": {
        "sha": { "type": "string" },
        "ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["passed", "failed", "invalid"] },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "order", "name", "status", "duration_ms"],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "skipped"] },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "metadata": { "type": "object" },
          "error": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assertion_id", "name", "severity", "status", "expected", "actual"],
        "properties": {
          "assertion_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["blocker", "major", "minor", "info"] },
          "status": { "enum": ["passed", "failed", "skipped"] },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "label", "type", "uri", "redaction_status"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": {
            "enum": [
              "json",
              "markdown",
              "screenshot",
              "video",
              "trace",
              "webhook_capture",
              "agent_transcript",
              "log_excerpt",
              "other"
            ]
          },
          "uri": { "type": "string", "minLength": 1 },
          "redaction_status": {
            "enum": ["not_required", "redacted", "contains_sensitive_synthetic_data"]
          },
          "checksum": { "type": "string" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "summary": { "type": "string" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
