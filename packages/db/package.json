{
  "name": "@spyglass/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -b",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "bench:f04-tickets": "tsx scripts/f04-ticket-benchmark.ts",
    "dev-run:f04": "tsx scripts/f04-staged-dev-run.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
