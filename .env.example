# Spyglass environment manifest — generated; do NOT edit by hand.
# Source of truth: packages/shared/src/env.ts
# Regenerate via `pnpm gen:env-example`.
# CI verifies this file matches the schema; drift = build failure.

# Vercel AI Gateway API key — required from F12
AI_GATEWAY_API_KEY=

# Clerk server-side secret — required from F02
CLERK_SECRET_KEY=

# Svix signing secret for the Clerk webhook endpoint (whsec_…) — required from F02 once webhooks are configured
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon Postgres connection URL — required from F03 onward
DATABASE_URL=

# Inngest event publish key — required from F08
INNGEST_EVENT_KEY=

# Inngest webhook signing key — required from F08
INNGEST_SIGNING_KEY=

# Clerk public key (browser-exposed) — required from F02
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Node runtime mode (development | preview | production | test)
NODE_ENV=

# Sentry DSN — required from F24
SENTRY_DSN=

# Comma-separated Clerk org IDs mapped to the Spyglass operator Organization (FR-9). Empty in dev.
SPYGLASS_OPERATOR_CLERK_ORG_IDS=

# Vercel deployment context (set automatically on Vercel)
VERCEL_ENV=
